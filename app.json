{
	"expo": {
		"name": "Diem",
		"slug": "diem",
		"scheme": "diem",
		"newArchEnabled": true,
		"version": "1.0.0",
		"orientation": "portrait",
		"userInterfaceStyle": "light",
		"splash": {
			"backgroundColor": "#F9FBFB"
		},
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "com.arshiyasalehi.diemapp"
		},
		"plugins": [
			[
				"expo-notifications",
				{
					"icon": "./assets/notification-icon.png",
					"color": "#F9FBFB"
				}
			],
			[
				"expo-build-properties",
				{
					"ios": {
						"deploymentTarget": "15.1",
						"useFrameworks": "static"
					}
				}
			]
		],
		"android": {
			"adaptiveIcon": {
				"backgroundColor": "#F9FBFB"
			},
			"package": "com.diem.app"
		}
	}
}
