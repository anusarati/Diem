{
	"name": "diem",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"devDependencies": {
		"@babel/plugin-proposal-decorators": "^7.29.0",
		"@biomejs/biome": "^2.4.7",
		"@react-native-community/cli": "^20.1.1",
		"@types/react": "~19.1.10",
		"babel-preset-expo": "~54.0.0",
		"lefthook": "^2.1.0",
		"nitrogen": "^0.33.9",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	},
	"main": "expo/AppEntry.js",
	"scripts": {
		"dev": "expo start",
		"start": "expo start",
		"test": "npm run test:all",
		"test:all": "npm run test:l1 && npm run test:vitest && npx tsc --noEmit && npx @biomejs/biome lint src tests vitest.config.ts package.json --error-on-warnings",
		"test:l1": "node --test tests/l1/*.test.mjs",
		"test:vitest": "vitest run",
		"test:vitest:watch": "vitest",
		"prepare": "lefthook install",
		"demo:solver": "cargo run --manifest-path rust/Cargo.toml --example quick_solver_demo",
		"android": "expo run:android",
		"ios": "expo run:ios"
	},
